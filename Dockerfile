###############################################################
# FastAPI Image
###############################################################

FROM multimodal-base:latest

WORKDIR /app

###############################################################
# Copy Project
###############################################################

COPY . .

###############################################################
# Expose API
###############################################################

EXPOSE 8000

###############################################################
# Run API
###############################################################

CMD ["uvicorn", "src.api.app:app", "--host", "0.0.0.0", "--port", "8000"]